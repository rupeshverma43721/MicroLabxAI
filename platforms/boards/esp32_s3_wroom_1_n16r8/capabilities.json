{
  "module": {
    "type": "wireless_mcu_module",
    "antenna": "pcb",
    "dimensions_mm": {
      "length": 18.0,
      "width": 25.5,
      "height": 3.1
    },
    "operating_voltage_v": {
      "min": 3.0,
      "max": 3.6
    },
    "ambient_temperature_c": {
      "min": -40,
      "max": 65
    },
    "notes": [
      "This profile describes the ESP32-S3-WROOM-1-N16R8 module.",
      "Actual usable pins depend on the carrier board that hosts the module."
    ]
  },
  "cpu": {
    "architecture": "Xtensa LX7",
    "cores": 2,
    "fpu": true,
    "max_frequency_mhz": 240,
    "ulp_coprocessor": true,
    "vector_instructions": true
  },
  "memory": {
    "flash": {
      "size_mb": 16,
      "interface": "Quad SPI",
      "max_clock_mhz": 80
    },
    "psram": {
      "size_mb": 8,
      "interface": "Octal SPI"
    },
    "internal": {
      "rom_kb": 384,
      "sram_kb": 512,
      "rtc_sram_kb": 16
    }
  },
  "wireless": {
