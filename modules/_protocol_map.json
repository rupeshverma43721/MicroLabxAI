{
  "protocols": {
    "gpio": {
      "description": "Direct GPIO pin control (LED, Relay, Button, etc.)",
      "default_config": {
        "pin": null,
        "active_high": true,
        "pull_up": false
      },
      "hint": "GPIO modules require a valid pin number from the current board."
    },
    "i2c": {
      "description": "I2C bus communication",
      "default_config": {
        "i2c_bus": 0,
        "address": null,
        "freq": 400000
      },
      "hint": "I2C modules use the board's default I2C bus and require an address."
    },
    "spi": {
      "description": "SPI bus communication",
      "default_config": {
        "spi_bus": 1,
        "cs_pin": null,
        "freq": 1000000
      },
      "hint": "SPI modules require a CS (Chip Select) pin."
    },
    "uart": {
      "description": "UART serial communication",
      "default_config": {
        "uart_id": 0,
        "tx_pin": null,
        "rx_pin": null,
        "baudrate": 115200
      },
      "hint": "UART modules require TX and RX pins."
    },
    "network": {
      "description": "Wi-Fi or BLE network devices",
      "default_config": {
        "interface": "wifi",
        "ssid": null,
        "password": null,
        "mac": null
      },
      "hint": "Network modules are for remote devices over Wi-Fi or BLE."
    }
  }
}